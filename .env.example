# ===========================================
# SICOOB API - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com suas credenciais do SICOOB
# NUNCA commit o arquivo .env no versionamento (git)

# -------------------------------------------
# Credenciais OAuth2 do SICOOB
# -------------------------------------------
# Token básico (Base64 de client_id:client_secret)
# Para gerar: echo -n "SEU_CLIENT_ID:SEU_CLIENT_SECRET" | base64
SICOOB_BASIC_TOKEN=

# Client ID fornecido pelo SICOOB
SICOOB_CLIENT_ID=

# Client Secret fornecido pelo SICOOB
SICOOB_CLIENT_SECRET=

# -------------------------------------------
# Dados da Conta Corrente
# -------------------------------------------
# Número da conta corrente
SICOOB_CONTA_CORRENTE=

# Número da cooperativa
SICOOB_COOPERATIVA=

# Chave de acesso fornecida pelo SICOOB
SICOOB_CHAVE_ACESSO=

# Número do contrato de cobrança
SICOOB_NUMERO_CONTRATO=

# Senha de acesso ao SICOOB (usada na geração do código de autorização)
SICOOB_PASSWORD=

# -------------------------------------------
# Configurações de Callback/Redirect
# -------------------------------------------
# URI de callback para OAuth2 (deve estar cadastrada no SICOOB)
SICOOB_CALLBACK_URI=

# -------------------------------------------
# Observações Importantes:
# -------------------------------------------
# 1. O SICOOB_BASIC_TOKEN deve ser gerado concatenando client_id:client_secret 
#    e codificando em Base64
#
# 2. A URI de callback deve estar previamente cadastrada no portal do SICOOB
#
# 3. Mantenha estas credenciais em segurança e nunca as compartilhe
#
# 4. Para uso em produção, considere usar um gerenciador de segredos
#
# Exemplo de geração do BASIC_TOKEN:
# Linux/Mac: echo -n "client_id:client_secret" | base64
# Windows PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes("client_id:client_secret"))
